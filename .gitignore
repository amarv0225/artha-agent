cat <<EOF > .gitignore
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.venv/
venv/
ENV/
env/
bin/
lib/
develop-eggs/
dist/
build/

# Secrets & Local Config
.env
auth-token.json
*.pem
*.key

# IDEs
.vscode/
.idea/

# Operating System
.DS_Store
Thumbs.db

# Project Specific
logs/
*.log
EOF